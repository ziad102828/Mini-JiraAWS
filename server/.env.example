# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── AWS General ──────────────────────────────────────────
AWS_REGION=us-east-1

# ─── Cognito ──────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── DynamoDB Table Names ─────────────────────────────────
DYNAMODB_USERS_TABLE=MiniJira_Users
DYNAMODB_TEAMS_TABLE=MiniJira_Teams
DYNAMODB_PROJECTS_TABLE=MiniJira_Projects
DYNAMODB_TASKS_TABLE=MiniJira_Tasks
DYNAMODB_COMMENTS_TABLE=MiniJira_Comments
DYNAMODB_AUDIT_TABLE=MiniJira_AuditLog

# ─── S3 Buckets ──────────────────────────────────────────
S3_ORIGINALS_BUCKET=minijira-originals-YOUR_UNIQUE_ID
S3_RESIZED_BUCKET=minijira-resized-YOUR_UNIQUE_ID

# ─── SNS ─────────────────────────────────────────────────
SNS_TASK_ASSIGNMENT_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:MiniJira-TaskAssignment

# ─── SQS ─────────────────────────────────────────────────
SQS_ASSIGNMENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/MiniJira-AssignmentQueue
